  "keyFeatures": [
    "Full Pathfinder Second Edition rules implementation",
    "Extensive actor types: character, NPC, familiar, hazard, vehicle, party, army",
    "Rich item types: spells, feats, ancestry, class, equipment, conditions, and more",
    "Rule Elements system for granular mechanical modifications",
    "Large compendium library with bestiary, spells, feats, and equipment",
    "Automated checks, damage rolls, and degree-of-success calculations",
    "Homebrew support for custom traits, languages, and damage types",
    "Migration system for data model version upgrades",
    "Foundry VTT hooks integration for extensibility"
  ],
  "publicApiSurface": [
    "RuleElement (base class for all rule modifications)",
    "ActorPF2e (base actor document)",
    "ItemPF2e (base item document)",
    "CharacterPF2e / NPCPF2e / FamiliarPF2e / HazardPF2e / VehiclePF2e / PartyPF2e / ArmyPF2e",
    "CheckPF2e (check rolls and dialogs)",
    "DamagePF2e (damage roll system)",
    "StatisticPF2e (statistics and modifiers)",
    "ConditionManager (condition tracking)",
    "MigrationRunner (data migration system)",
    "CompendiumBrowser (in-app content browser)"
  ]
}
